/**\file
 * Implementation of functions to write messages usually generated by game
 */
#ifndef Q2PROTO_BUILD
#define Q2PROTO_BUILD
#endif // Q2PROTO_BUILD
#include "q2proto/q2proto.h"

#if !defined(WRITE_GAME_DIRECTION)
#define WRITE_GAME_DIRECTION q2proto_common_server_write_packed_direction
#endif

#if !defined(WRITE_TEMP_ENTITY_DECL)
#define WRITE_TEMP_ENTITY_DECL
#define _WRITE_TEMP_ENTITY_DECL_DEFAULTED
#endif

WRITE_TEMP_ENTITY_DECL q2proto_error_t WRITE_TEMP_ENTITY_NAME(uintptr_t io_arg, q2proto_game_api_t game_api,
                                                              const q2proto_svc_temp_entity_t *temp_entity)
{
    WRITE_CHECKED(server_write, io_arg, u8, svc_temp_entity);
    WRITE_CHECKED(server_write, io_arg, u8, temp_entity->type);

    switch (temp_entity->type) {
    case TE_BLOOD:
    case TE_GUNSHOT:
    case TE_SPARKS:
    case TE_BULLET_SPARKS:
    case TE_SCREEN_SPARKS:
    case TE_SHIELD_SPARKS:
    case TE_SHOTGUN:
    case TE_BLASTER:
    case TE_GREENBLOOD:
    case TE_BLASTER2:
    case TE_FLECHETTE:
    case TE_HEATBEAM_SPARKS:
    case TE_HEATBEAM_STEAM:
    case TE_MOREBLOOD:
    case TE_ELECTRIC_SPARKS:
    case TE_BLUEHYPERBLASTER_2:
    case TE_BERSERK_SLAM:
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position1));
        CHECKED(server_write, io_arg, WRITE_GAME_DIRECTION(io_arg, temp_entity->direction));
        break;

    case TE_SPLASH:
    case TE_LASER_SPARKS:
    case TE_WELDING_SPARKS:
    case TE_TUNNEL_SPARKS:
        WRITE_CHECKED(server_write, io_arg, u8, temp_entity->count);
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position1));
        CHECKED(server_write, io_arg, WRITE_GAME_DIRECTION(io_arg, temp_entity->direction));
        WRITE_CHECKED(server_write, io_arg, u8, temp_entity->color);
        break;

    case TE_BLUEHYPERBLASTER:
    case TE_RAILTRAIL:
    case TE_RAILTRAIL2:
    case TE_BUBBLETRAIL:
    case TE_DEBUGTRAIL:
    case TE_BUBBLETRAIL2:
    case TE_BFG_LASER:
    case TE_BFG_ZAP:
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position1));
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position2));
        break;

    case TE_GRENADE_EXPLOSION:
    case TE_GRENADE_EXPLOSION_WATER:
    case TE_EXPLOSION2:
    case TE_PLASMA_EXPLOSION:
    case TE_ROCKET_EXPLOSION:
    case TE_ROCKET_EXPLOSION_WATER:
    case TE_EXPLOSION1:
    case TE_EXPLOSION1_NP:
    case TE_EXPLOSION1_BIG:
    case TE_BFG_EXPLOSION:
    case TE_BFG_BIGEXPLOSION:
    case TE_BOSSTPORT:
    case TE_PLAIN_EXPLOSION:
    case TE_CHAINFIST_SMOKE:
    case TE_TRACKER_EXPLOSION:
    case TE_TELEPORT_EFFECT:
    case TE_DBALL_GOAL:
    case TE_WIDOWSPLASH:
    case TE_NUKEBLAST:
    case TE_EXPLOSION1_NL:
    case TE_EXPLOSION2_NL:
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position1));
        break;

    case TE_PARASITE_ATTACK:
    case TE_MEDIC_CABLE_ATTACK:
    case TE_HEATBEAM:
    case TE_MONSTER_HEATBEAM:
    case TE_GRAPPLE_CABLE_2:
    case TE_LIGHTNING_BEAM:
        WRITE_CHECKED(server_write, io_arg, i16, temp_entity->entity1);
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position1));
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position2));
        break;

    case TE_GRAPPLE_CABLE:
        WRITE_CHECKED(server_write, io_arg, i16, temp_entity->entity1);
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position1));
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position2));
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->offset));
        break;

    case TE_LIGHTNING:
        WRITE_CHECKED(server_write, io_arg, i16, temp_entity->entity1);
        WRITE_CHECKED(server_write, io_arg, i16, temp_entity->entity2);
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position1));
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position2));
        break;

    case TE_FLASHLIGHT:
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position1));
        WRITE_CHECKED(server_write, io_arg, i16, temp_entity->entity1);
        break;

    case TE_FORCEWALL:
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position1));
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position2));
        WRITE_CHECKED(server_write, io_arg, u8, temp_entity->color);
        break;

    case TE_STEAM:
        WRITE_CHECKED(server_write, io_arg, i16, temp_entity->entity1);
        WRITE_CHECKED(server_write, io_arg, u8, temp_entity->count);
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position1));
        CHECKED(server_write, io_arg, WRITE_GAME_DIRECTION(io_arg, temp_entity->direction));
        WRITE_CHECKED(server_write, io_arg, u8, temp_entity->color);
        WRITE_CHECKED(server_write, io_arg, i16, temp_entity->entity2);
        if (temp_entity->entity1 != -1) {
            WRITE_CHECKED(server_write, io_arg, i32, temp_entity->time);
        }
        break;

    case TE_WIDOWBEAMOUT:
        WRITE_CHECKED(server_write, io_arg, i16, temp_entity->entity1);
        CHECKED(server_write, io_arg, WRITE_GAME_POSITION(io_arg, temp_entity->position1));
        break;

    case TE_POWER_SPLASH:
        WRITE_CHECKED(server_write, io_arg, i16, temp_entity->entity1);
        WRITE_CHECKED(server_write, io_arg, u8, temp_entity->count);
        break;

    case TE_Q2PRO_DAMAGE_DEALT:
        if (game_api == Q2PROTO_GAME_Q2PRO_EXTENDED || game_api == Q2PROTO_GAME_Q2PRO_EXTENDED_V2) {
            WRITE_CHECKED(server_write, io_arg, i16, temp_entity->count);
            break;
        }
        // not supported in other game APIs, fall through

    default:
        return HANDLE_ERROR(server_write, io_arg, Q2P_ERR_BAD_DATA, "%s: invalid tent %d", __func__, temp_entity->type);
    }

    return Q2P_ERR_SUCCESS;
}

#if defined(_WRITE_TEMP_ENTITY_DECL_DEFAULTED)
#undef _WRITE_TEMP_ENTITY_DECL_DEFAULTED
#undef WRITE_TEMP_ENTITY_DECL
#endif // _WRITE_TEMP_ENTITY_DECL_DEFAULTED
